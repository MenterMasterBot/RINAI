cat > "$PROXY_SCRIPT_DIR/rin-proxy.sh" << 'JBEOF'
#!/usr/bin/env bash
set -euo pipefail

# Rin Jailbreak Proxy Rotation
# Fetches free proxies to bypass IP-based rate limits

PROXY_DIR="${RIN_PROXY_DIR:-$(dirname "$0")/../.rin-proxy}"
mkdir -p "$PROXY_DIR"

PROXY_SOURCES=(
    "https://api.proxyscrape.com/?request=getproxies&proxytype=http&timeout=10000&country=all&ssl=all&anonymity=all"
    "https://raw.githubusercontent.com/TheSpeedX/SOCKS-Proxy-List/master/http.txt"
    "https://raw.githubusercontent.com/monosans/proxy-list/main/proxies/http.txt"
    "https://raw.githubusercontent.com/ShiftyTR/Proxy-List/master/http.txt"
    "https://raw.githubusercontent.com/proxy4parsing/proxy-list/main/http.txt"
)

fetch_proxies() {
    local all_proxies=""
    for url in "${PROXY_SOURCES[@]}"; do
        echo -e "\033[0;2mFetching: $url\033[0m" >&2
        local data
        data=$(curl -s --max-time 15 "$url" 2>/dev/null || true)
        all_proxies="$all_proxies"$'\n'"$data"
    done
    echo "$all_proxies" | tr ',' '\n' | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+:[0-9]+' | sort -u | shuf
}

validate_proxy() {
    local proxy=$1
    local timeout=${2:-5}
    if curl -s --max-time "$timeout" -x "http://$proxy" -o /dev/null -w "%{http_code}" "http://httpbin.org/ip" 2>/dev/null | grep -qE '^[0-9]+$'; then
        echo "$proxy"
    fi
}

validate_proxies() {
    local count=0
    local max=${1:-50}
    while IFS= read -r proxy; do
        [ -z "$proxy" ] && continue
        [ "$count" -ge "$max" ] && break
        if result=$(validate_proxy "$proxy" 5); then
            echo "$result"
            count=$((count + 1))
        fi
    done
}

CACHE_FILE="$PROXY_DIR/proxies.txt"
VALIDATED_FILE="$PROXY_DIR/validated.txt"

case "${1:-}" in
    --all)
        fetch_proxies | tee "$CACHE_FILE" | validate_proxies 999999 | tee "$VALIDATED_FILE"
        echo "" >&2
        echo "Valid proxies: $(wc -l < "$VALIDATED_FILE" 2>/dev/null || echo 0)" >&2
        ;;
    --export)
        if [ -f "$VALIDATED_FILE" ]; then
            cat "$VALIDATED_FILE" | paste -sd ","
        else
            fetch_proxies | validate_proxies 50 | tee "$VALIDATED_FILE" | paste -sd ","
        fi
        ;;
    --watch)
        echo "Starting proxy refresher (every 5 minutes)..." >&2
        while true; do
            fetch_proxies | validate_proxies 100 > "$VALIDATED_FILE" 2>/dev/null
            cat "$VALIDATED_FILE" | paste -sd "," > /tmp/rin_proxies_export.txt
            echo "[$(date '+%H:%M:%S')] Proxies: $(wc -l < "$VALIDATED_FILE")" >&2
            sleep 300
        done
        ;;
    --count)
        if [ -f "$VALIDATED_FILE" ]; then
            wc -l < "$VALIDATED_FILE"
        else
            echo 0
        fi
        ;;
    "")
        fetch_proxies | validate_proxies 100 | tee "$VALIDATED_FILE"
        echo "" >&2
        echo "Valid proxies: $(wc -l < "$VALIDATED_FILE" 2>/dev/null || echo 0)" >&2
        ;;
    *)
        echo "Usage: rin-proxy.sh [--all|--export|--watch|--count]"
        exit 1
        ;;
esac
JBEOF
chmod +x "$PROXY_SCRIPT_DIR/rin-proxy.sh"
echo -e "${GREEN}  ✅ Created:${NC} $PROXY_SCRIPT_DIR/rin-proxy.sh"


#!/usr/bin/env bash
set -euo pipefail

# Rin Jailbreak Launcher
# Starts rin with proxy rotation and unrestricted config

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="$HOME/.config/rin"
PROXY_SCRIPT="$SCRIPT_DIR/rin-proxy.sh"
RIN_BIN="${RIN_BIN:-$HOME/.rin/bin/rin}"

use_tor=false
use_dev=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --tor) use_tor=true; shift ;;
        --dev) use_dev=true; shift ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

if [ ! -f "$RIN_BIN" ]; then
    echo "Rin binary not found at $RIN_BIN"
    echo "Install first: curl -fsSL https://mentermasterbot.github.io/Hello-World/rin | bash -s -- -j"
    exit 1
fi

echo "Fetching proxy list..."
RIN_PROXIES=$(bash "$PROXY_SCRIPT" --export 2>/dev/null || echo "")
export RIN_PROXIES

if [ "$use_tor" = true ]; then
    export RIN_USE_TOR=true
    echo "Tor routing enabled"
fi

echo "Starting Rin with jailbreak config..."
echo "  Config: $CONFIG_DIR/opencode.json"
echo ""

if [ "$use_dev" = true ]; then
    exec "$RIN_BIN" --config "$CONFIG_DIR/opencode.json" --dev "$@"
else
    exec "$RIN_BIN" --config "$CONFIG_DIR/opencode.json" "$@"
fi
JBEOF
chmod +x "$PROXY_SCRIPT_DIR/rin-start.sh"
echo -e "${GREEN}  ✅ Created:${NC} $PROXY_SCRIPT_DIR/rin-start.sh"

echo ""
echo -e "${GREEN}═══════════════════════════════════════════════${NC}"
echo -e "${GREEN}   RIN JAILBREAK INSTALLED SUCCESSFULLY!       ${NC}"
echo -e "${GREEN}═══════════════════════════════════════════════${NC}"
echo ""
echo -e "Run Rin with jailbreak config:"
echo -e "  ${CYAN}rin --config ~/.config/rin/opencode.json${NC}"
echo ""
echo -e "Or use the launcher:"
echo -e "  ${CYAN}bash ~/.config/rin/bin/rin-start.sh${NC}"
echo ""
echo -e "With proxy rotation:"
echo -e "  ${CYAN}RIN_PROXIES=\$(bash ~/.config/rin/bin/rin-proxy.sh --export) rin${NC}"
echo ""

else
    # ── Normal mode output ──
    echo -e ""
    echo -e "${MUTED}Rin includes free models, to start:${NC}"
    echo -e ""
    echo -e "cd <project>  ${MUTED}# Open directory${NC}"
    echo -e "rin           ${MUTED}# Run command${NC}"
    echo -e ""
    echo -e "${MUTED}For jailbreak mode: curl -fsSL https://mentermasterbot.github.io/Hello-World/rin | bash -s -- -j${NC}"
    echo -e ""
fi
